# Optional: copy to `.env` in the repo root for `docker compose` variable substitution.
# Server, worker, and CLI/Web Settings must use the same value.
API_KEY=dev-key-change-in-production
# Worker image only: pin Cursor CLI package if the default 404s (see Dockerfile.worker).
# CURSOR_AGENT_VERSION=2026.03.20-44cb435
# Browser UI on another origin (e.g. Vite :5173) needs an exact match here:
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
#
# GitLab OAuth (all three required for Sign in with GitLab). `cargo run -p server` and
# Docker Compose both read this file when configured as in README / docker-compose.yml.
# GITLAB_CLIENT_ID=
# GITLAB_CLIENT_SECRET=
# GITLAB_REDIRECT_URI=http://localhost:3000/auth/gitlab/callback
# REDIRECT_AFTER_AUTH=http://localhost:5173/settings
