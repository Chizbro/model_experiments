# Database
DATABASE_URL=postgres://localhost:5432/remote_harness

# Auth - comma-separated API keys (at least one required for authenticated endpoints)
API_KEY=your-api-key-here
# API_KEYS=key1,key2,key3

# Server bind
HOST=0.0.0.0
PORT=3000

# Worker staleness threshold (seconds)
WORKER_STALE_SECONDS=90

# Job settings
MAX_JOB_RECLAIMS=3
JOB_LEASE_SECONDS=600

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Chat history
CHAT_HISTORY_MAX_TURNS=50

# Docker Compose overrides (used by docker-compose.yml)
# DATABASE_URL=postgres://postgres:postgres@postgres:5432/remote_harness

# OAuth (optional)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URI=
# GITLAB_CLIENT_ID=
# GITLAB_CLIENT_SECRET=
# GITLAB_REDIRECT_URI=
# GITLAB_BASE_URL=https://gitlab.com
# REDIRECT_AFTER_AUTH=http://localhost:5173/settings
