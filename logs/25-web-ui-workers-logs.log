import { useState } from "react";
import { useParams, useNavigate } from "react-router-dom";
import {
  useSession,
  useUpdateSession,
  useDeleteSession,
  useDeleteSessionLogs,
  useSendInput,
} from "@/lib/query";
import { useSessionEvents } from "@/lib/sse";
import { useQueryClient } from "@tanstack/react-query";
import { queryKeys } from "@/lib/query";
import type { JobSummary, SessionDetail, BranchMode } from "@/lib/types";
import { Button } from "@/components/ui/button";

const statusBadge: Record<string, string> = {
  pending: "bg-yellow-500/10 text-yellow-500",
  running: "bg-blue-500/10 text-blue-500",
  completed: "bg-green-500/10 text-green-500",
  failed: "bg-red-500/10 text-red-500",
};

function JobOutcomeHint({ job, branchMode }: { job: JobSummary; branchMode?: BranchMode }) {
  // CLIENT_EXPERIENCE §8 compliance
  if (job.status === "failed" && job.error_message) {
    return (
      <div className="mt-2 rounded-md bg-red-500/10 p-3 text-sm text-destructive">
        <p className="font-medium">Error: {job.error_message}</p>
        {(job.error_message.includes("auth") ||
          job.error_message.includes("git") ||
          job.error_message.includes("token")) && (
          <p className="mt-1 text-xs text-muted-foreground">
            Check Settings → Credentials to refresh your tokens.
          </p>
        )}
      </div>
    );
  }

  if (job.status === "completed" && !job.commit_ref) {
    return (
      <p className="mt-1 text-xs text-muted-foreground">
        Job completed but no commit was pushed. Check logs for details.
      </p>
    );
  }

  if (
    job.status === "completed" &&
    branchMode === "pr" &&
    job.commit_ref &&
    !job.pull_request_url
  ) {
    return (
      <p className="mt-1 text-xs text-muted-foreground">
        PR/MR was not created despite PR mode. Possible reasons: missing branch/title in
        payload, provider API error, or token scope issue.
      </p>
    );
  }

  return null;
}

function ConfirmDialog({
  title,
  message,
  onConfirm,
  onCancel,
}: {
  title: string;
  message: string;
  onConfirm: () => void;
  onCancel: () => void;
}) {
  return (
    <div className="fixed inset-0 z-50 flex items-center justify-center bg-black/50">
      <div className="w-full max-w-sm rounded-lg border border-border bg-card p-6 shadow-lg">
        <h3 className="text-lg font-semibold">{title}</h3>
        <p className="mt-2 text-sm text-muted-foreground">{message}</p>
        <div className="mt-4 flex justify-end gap-2">
          <Button variant="outline" size="sm" onClick={onCancel}>
            Cancel
          </Button>
          <Button variant="destructive" size="sm" onClick={onConfirm}>
            Confirm
          </Button>
        </div>
      </div>
    </div>
  );
}

export function SessionDetailPage() {
  const { id } = useParams<{ id: string }>();
  const navigate = useNavigate();
  const queryClient = useQueryClient();
  const { data, isLoading, error } = useSession(id);
  const updateSession = useUpdateSession(id ?? "");
  const deleteSession = useDeleteSession();
  const deleteLogs = useDeleteSessionLogs(id ?? "");
  const sendInput = useSendInput(id ?? "");

  const [chatMessage, setChatMessage] = useState("");
  const [confirmAction, setConfirmAction] = useState<
    null | "delete" | "delete_logs"
  >(null);

  // SSE for real-time session events
  const { data: events } = useSessionEvents(id);

  // Invalidate session query when we get new events
  const lastEventCount = events.length;
  if (lastEventCount > 0) {
    // Re-fetch session data when events arrive
    queryClient.invalidateQueries({ queryKey: queryKeys.session(id!) });
  }

  if (isLoading) return <p className="text-muted-foreground">Loading...</p>;
  if (error)
    return (
      <p className="text-destructive">Error: {(error as Error).message}</p>
    );
  if (!data) return <p className="text-muted-foreground">Session not found.</p>;

  const session: SessionDetail = data;
  const branchMode = session.params?.branch_mode;
  const isChat = session.workflow === "chat";
  const isRunning = session.status === "running";

  function handleRetainToggle() {
    updateSession.mutate({ retain_forever: !session.retain_forever });
  }

  function handleDelete() {
    deleteSession.mutate(id!, {
      onSuccess: () => navigate("/"),
    });
  }

  function handleDeleteLogs() {
    deleteLogs.mutate(undefined, {
      onSuccess: () => setConfirmAction(null),
    });
  }

  function handleSendChat(e: React.FormEvent) {
    e.preventDefault();
    if (!chatMessage.trim()) return;
    sendInput.mutate(
      { message: chatMessage },
      { onSuccess: () => setChatMessage("") },
    );
  }

  return (
    <div className="space-y-6">
      {/* ... header, info, jobs table, chat input ... */}

      {/* Log panel placeholder (Task 25) */}
      <div className="rounded-lg border border-border p-4">
        <h3 className="text-sm font-medium text-muted-foreground">
          Log viewer will be added in Task 25
        </h3>
      </div>
    </div>
  );
}

