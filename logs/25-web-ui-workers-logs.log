--- web/src/components/LogViewer.tsx ---
import { useState, useEffect, useRef, useCallback, useMemo } from "react";
import { useVirtualizer } from "@tanstack/react-virtual";
import { useSessionLogs } from "@/lib/query";
import { useLogStream, type SSEStatus } from "@/lib/sse";
import type { LogEntry, LogLevel, JobId } from "@/lib/types";
import { Button } from "@/components/ui/button";

// ── Props ───────────────────────────────────────────────────────────────

interface LogViewerProps {
  sessionId: string;
  jobId?: JobId;
  level?: LogLevel;
  /** Jobs available for the job filter dropdown */
  jobs?: { job_id: string; status: string }[];
  /** If true, collapse to a summary line */
  collapsed?: boolean;
}

// ── Level colors ────────────────────────────────────────────────────────

const levelClass: Record<LogLevel, string> = {
  debug: "text-muted-foreground",
  info: "text-foreground",
  warn: "text-yellow-500",
  error: "text-red-500",
};

const levelBadgeClass: Record<LogLevel, string> = {
  debug: "bg-muted text-muted-foreground",
  info: "bg-blue-500/10 text-blue-500",
  warn: "bg-yellow-500/10 text-yellow-500",
  error: "bg-red-500/10 text-red-500",
};

const sourceBadgeClass: Record<string, string> = {
  agent: "bg-purple-500/10 text-purple-500",
  worker: "bg-cyan-500/10 text-cyan-500",
  control_plane: "bg-orange-500/10 text-orange-500",
};

// ── Component ───────────────────────────────────────────────────────────

export function LogViewer({
  sessionId,
  jobId: initialJobId,
  level: initialLevel,
  jobs,
  collapsed,
}: LogViewerProps) {
  const [levelFilter, setLevelFilter] = useState<LogLevel | undefined>(
    initialLevel,
  );
  const [jobFilter, setJobFilter] = useState<string | undefined>(
    initialJobId,
  );
  const [stickToBottom, setStickToBottom] = useState(true);

  // Fetch history
  const {
    data: historyData,
    isLoading: historyLoading,
  } = useSessionLogs(sessionId, {
    jobId: jobFilter,
    level: levelFilter,
    last: 500,
  });

  // SSE stream
  const {
    data: streamEntries,
    status: sseStatus,
  } = useLogStream(sessionId, jobFilter, levelFilter);

  // Merge history + stream, deduplicate by id
  const entries = useMemo(() => {
    const historyItems = historyData?.items ?? [];
    const seen = new Set(historyItems.map((e) => e.id));
    const newFromStream = streamEntries.filter((e) => !seen.has(e.id));
    return [...historyItems, ...newFromStream];
  }, [historyData, streamEntries]);

  // Virtualizer
  const parentRef = useRef<HTMLDivElement>(null);
  const virtualizer = useVirtualizer({
    count: entries.length,
    getScrollElement: () => parentRef.current,
    estimateSize: () => 28,
    overscan: 20,
  });

  // Auto-scroll to bottom
  useEffect(() => {
    if (stickToBottom && entries.length > 0) {
      virtualizer.scrollToIndex(entries.length - 1, { align: "end" });
    }
  }, [entries.length, stickToBottom, virtualizer]);

  // Detect manual scroll up to disable stick
  const handleScroll = useCallback(() => {
    const el = parentRef.current;
    if (!el) return;
    const atBottom = el.scrollHeight - el.scrollTop - el.clientHeight < 50;
    setStickToBottom(atBottom);
  }, []);

  if (collapsed) {
    return (
      <div className="rounded-lg border border-border p-4">
        <p className="text-sm text-muted-foreground">
          Session complete — {entries.length} log entries recorded.
        </p>
      </div>
    );
  }

  return (
    <div className="flex flex-col rounded-lg border border-border">
      {/* Toolbar */}
      <div className="flex items-center gap-3 border-b border-border px-4 py-2">
        <h3 className="text-sm font-medium">Logs</h3>

        {/* Level filter */}
        <select
          value={levelFilter ?? ""}
          onChange={(e) =>
            setLevelFilter((e.target.value || undefined) as LogLevel | undefined)
          }
          className="rounded-md border border-input bg-background px-2 py-1 text-xs outline-none"
        >
          <option value="">All levels</option>
          <option value="debug">Debug</option>
          <option value="info">Info</option>
          <option value="warn">Warn</option>
          <option value="error">Error</option>
        </select>

        {/* Job filter */}
        {jobs && jobs.length > 0 && (
          <select
            value={jobFilter ?? ""}
            onChange={(e) =>
              setJobFilter(e.target.value || undefined)
            }
            className="rounded-md border border-input bg-background px-2 py-1 text-xs outline-none"
          >
            <option value="">All jobs</option>
            {jobs.map((j) => (
              <option key={j.job_id} value={j.job_id}>
                {j.job_id.slice(0, 8)} ({j.status})
              </option>
            ))}
          </select>
        )}

        <div className="flex-1" />

        {/* SSE status */}
        <SSEStatusBadge status={sseStatus} />

        {/* Stick to bottom toggle */}
        <Button
          variant={stickToBottom ? "secondary" : "outline"}
          size="xs"
          onClick={() => {
            setStickToBottom(true);
            if (entries.length > 0) {
              virtualizer.scrollToIndex(entries.length - 1, { align: "end" });
            }
          }}
        >
          {stickToBottom ? "Auto-scroll on" : "Auto-scroll off"}
        </Button>
      </div>

      {/* Log content */}
      {historyLoading ? (
        <div className="flex items-center justify-center p-8">
          <p className="text-sm text-muted-foreground">Loading logs...</p>
        </div>
      ) : entries.length === 0 ? (
        <div className="flex items-center justify-center p-8">
          <p className="text-sm text-muted-foreground">No log entries.</p>
        </div>
      ) : (
        <div
          ref={parentRef}
          onScroll={handleScroll}
          className="h-[400px] overflow-auto font-mono text-xs"
        >
          <div
            style={{
              height: `${virtualizer.getTotalSize()}px`,
              width: "100%",
              position: "relative",
            }}
          >
            {virtualizer.getVirtualItems().map((virtualRow) => {
              const entry = entries[virtualRow.index];
              return (
                <div
                  key={virtualRow.key}
                  data-index={virtualRow.index}
                  ref={virtualizer.measureElement}
                  style={{
                    position: "absolute",
                    top: 0,
                    left: 0,
                    width: "100%",
                    transform: `translateY(${virtualRow.start}px)`,
                  }}
                  className="flex items-baseline gap-2 px-4 py-0.5 hover:bg-muted/50"
                >
                  <LogEntryLine entry={entry} />
                </div>
              );
            })}
          </div>
        </div>
      )}
    </div>
  );
}

// ── Sub-components ──────────────────────────────────────────────────────

function LogEntryLine({ entry }: { entry: LogEntry }) {
  const time = new Date(entry.timestamp);
  const hh = String(time.getHours()).padStart(2, "0");
  const mm = String(time.getMinutes()).padStart(2, "0");
  const ss = String(time.getSeconds()).padStart(2, "0");

  return (
    <>
      <span className="shrink-0 text-muted-foreground">
        [{hh}:{mm}:{ss}]
      </span>
      <span
        className={`shrink-0 inline-flex rounded px-1 py-0 text-[10px] font-medium uppercase ${levelBadgeClass[entry.level] ?? ""}`}
      >
        {entry.level}
      </span>
      <span
        className={`shrink-0 inline-flex rounded px-1 py-0 text-[10px] font-medium ${sourceBadgeClass[entry.source] ?? "bg-muted text-muted-foreground"}`}
      >
        {entry.source}
      </span>
      <span className={`min-w-0 break-all ${levelClass[entry.level] ?? ""}`}>
        {entry.message}
      </span>
    </>
  );
}

function SSEStatusBadge({ status }: { status: SSEStatus }) {
  if (status === "open") {
    return (
      <span className="inline-flex items-center gap-1 text-xs text-green-500">
        <span className="h-1.5 w-1.5 rounded-full bg-green-500" />
        Live
      </span>
    );
  }
  if (status === "reconnecting") {
    return (
      <span className="inline-flex items-center gap-1 text-xs text-yellow-500">
        <span className="h-1.5 w-1.5 rounded-full bg-yellow-500 animate-pulse" />
        Reconnecting...
      </span>
    );
  }
  if (status === "connecting") {
    return (
      <span className="inline-flex items-center gap-1 text-xs text-muted-foreground">
        <span className="h-1.5 w-1.5 rounded-full bg-muted-foreground animate-pulse" />
        Connecting...
      </span>
    );
  }
  return null;
}

