import { useState } from "react";
import { useWorkers, useDeleteWorker } from "@/lib/query";
import { Button } from "@/components/ui/button";
import type { WorkerSummary } from "@/lib/types";

function getPlatformLabel(worker: WorkerSummary): string | undefined {
  return worker.labels?.find(
    (l) =>
      l.startsWith("platform=") ||
      l.startsWith("os=") ||
      ["windows", "linux", "macos", "wsl", "darwin"].includes(l.toLowerCase()),
  );
}

function detectHeterogeneity(workers: WorkerSummary[]): string | null {
  const active = workers.filter(
    (w) => w.connection_status === "active" || w.status !== "idle",
  );
  if (active.length < 2) return null;

  const platforms = new Set<string>();
  let hasWsl = false;
  let hasWindowsNative = false;

  for (const w of active) {
    const label = getPlatformLabel(w);
    if (label) {
      const val = label.includes("=") ? label.split("=")[1] : label;
      const lower = val.toLowerCase();
      platforms.add(lower);
      if (lower === "wsl") hasWsl = true;
      if (lower === "windows") hasWindowsNative = true;
    }
  }

  if (hasWsl && hasWindowsNative) {
    return "Mixed worker pool detected (WSL + native Windows). The engine may assign any session to any worker. Mixed OS or missing CLIs can cause failures.";
  }

  if (platforms.size >= 2) {
    return "Mixed worker pool detected. The engine may assign any session to any worker. Mixed OS or missing CLIs can cause failures.";
  }

  return null;
}

function ConfirmDialog({ title, message, onConfirm, onCancel }: { title: string; message: string; onConfirm: () => void; onCancel: () => void; }) {
  return (
    <div className="fixed inset-0 z-50 flex items-center justify-center bg-black/50">
      <div className="w-full max-w-sm rounded-lg border border-border bg-card p-6 shadow-lg">
        <h3 className="text-lg font-semibold">{title}</h3>
        <p className="mt-2 text-sm text-muted-foreground">{message}</p>
        <div className="mt-4 flex justify-end gap-2">
          <Button variant="outline" size="sm" onClick={onCancel}>Cancel</Button>
          <Button variant="destructive" size="sm" onClick={onConfirm}>Confirm</Button>
        </div>
      </div>
    </div>
  );
}

export function WorkersPage() {
  const { data, isLoading, error } = useWorkers();
  const deleteWorker = useDeleteWorker();
  const [confirmDeleteId, setConfirmDeleteId] = useState<string | null>(null);

  const workers = data?.items ?? [];
  const heterogeneityWarning = detectHeterogeneity(workers);

  function handleDelete() {
    if (!confirmDeleteId) return;
    deleteWorker.mutate(confirmDeleteId, {
      onSuccess: () => setConfirmDeleteId(null),
    });
  }

  return (
    <div className="space-y-6">
      <h1 className="text-2xl font-bold">Workers</h1>

      {confirmDeleteId && (
        <ConfirmDialog
          title="Remove Worker"
          message="This will remove the worker registration and reclaim any assigned jobs. The worker process (if running) will re-register on its next heartbeat."
          onConfirm={handleDelete}
          onCancel={() => setConfirmDeleteId(null)}
        />
      )}

      {heterogeneityWarning && (
        <div className="rounded-lg border border-yellow-500/30 bg-yellow-500/10 p-4 text-sm text-yellow-600 dark:text-yellow-400">
          <p className="font-medium">Warning: {heterogeneityWarning}</p>
        </div>
      )}

      {isLoading && <p className="text-muted-foreground">Loading workers...</p>}
      {error && (
        <p className="text-destructive">Failed to load workers: {(error as Error).message}</p>
      )}
      {data && workers.length === 0 && (
        <p className="text-muted-foreground">No workers registered.</p>
      )}
      {workers.length > 0 && (
        <div className="rounded-lg border border-border">
          <table className="w-full text-sm">
            <thead>
              <tr className="border-b border-border text-left text-muted-foreground">
                <th className="px-4 py-3 font-medium">Worker</th>
                <th className="px-4 py-3 font-medium">Host</th>
                <th className="px-4 py-3 font-medium">Platform</th>
                <th className="px-4 py-3 font-medium">Status</th>
                <th className="px-4 py-3 font-medium">Last Seen</th>
                <th className="px-4 py-3 font-medium w-20"></th>
              </tr>
            </thead>
            <tbody>
              {workers.map((w) => {
                const connStatus = w.connection_status ?? "active";
                const platform = getPlatformLabel(w);
                return (
                  <tr key={w.worker_id} className="border-b border-border last:border-0">
                    <td className="px-4 py-3 font-mono text-xs">{w.worker_id.slice(0, 12)}</td>
                    <td className="px-4 py-3">{w.host}</td>
                    <td className="px-4 py-3 text-xs text-muted-foreground">{platform ?? "—"}</td>
                    <td className="px-4 py-3">
                      <span className={`inline-flex rounded-full px-2 py-0.5 text-xs font-medium ${connStatus === "active" ? "bg-green-500/10 text-green-500" : "bg-red-500/10 text-red-500"}`}>
                        {connStatus}
                      </span>
                    </td>
                    <td className="px-4 py-3 text-muted-foreground">
                      {w.last_seen_at ? new Date(w.last_seen_at).toLocaleString() : "—"}
                    </td>
                    <td className="px-4 py-3">
                      <Button variant="ghost" size="xs" className="text-destructive hover:text-destructive" onClick={() => setConfirmDeleteId(w.worker_id)} disabled={deleteWorker.isPending}>
                        Remove
                      </Button>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      )}
    </div>
  );
}

