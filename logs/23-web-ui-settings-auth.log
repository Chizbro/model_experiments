### 2. web/src/lib/query.ts - Added bootstrap mutation

```typescript
import { api, bootstrapApiKey } from "./api";

export function useBootstrapApiKey() {
  const qc = useQueryClient();
  return useMutation({
    mutationFn: (data: { controlPlaneUrl: string; label: string }) =>
      bootstrapApiKey(data.controlPlaneUrl, data.label),
    onSuccess: () => qc.invalidateQueries({ queryKey: queryKeys.apiKeys }),
  });
}
```

