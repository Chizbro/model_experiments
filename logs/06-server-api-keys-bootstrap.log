# Remote Harness — REST contract (OpenAPI 3.0.3)
#
# Canonical artifact for JSON routes. Keep this file aligned with docs/API_OVERVIEW.md.
#
# SSE: Event field names and examples are documented in docs/SSE_EVENTS.md (companion).
#      See docs/PROJECT_KICKOFF.md §6 — Communication & Docs.
#
openapi: 3.0.3
info:
  title: Remote Harness Control Plane API
  version: 0.1.0
  description: |
    Control plane REST API. Human-readable API prose and behavior notes live in
    `docs/API_OVERVIEW.md`; this spec is the machine-readable contract for codegen and review.

servers:
  - url: /
    description: Relative to configured control plane base URL

tags:
  - name: health
    description: Liveness and readiness (no authentication)
  - name: apiKeys
    description: Control plane API keys (bootstrap, create, list, revoke)
  - name: sessions
    description: Session lifecycle (API key required when implemented)

paths:
  /health:
    get:
      tags: [health]
      summary: Liveness probe
      operationId: getHealth
      responses:
        "200":
          description: Service is running
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/HealthStatus"

  /ready:
    get:
      tags: [health]
      summary: Readiness probe
      operationId: getReady
      responses:
        "200":
          description: Service is ready to accept traffic
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/HealthStatus"
        "503":
          description: Not ready (e.g. database unreachable when DATABASE_URL is set)
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/StandardError"

  /health/idle:
    get:
      tags: [health]
      summary: Idle check for sleep-inhibit helpers
      operationId: getHealthIdle
      responses:
        "200":
          description: No pending or assigned jobs (safe to idle)
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/IdleCheckOk"
        "503":
          description: Work is queued or assigned (hold sleep inhibit)
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/IdleCheckBusy"

  /api-keys/bootstrap:
    post:
      tags: [apiKeys]
      summary: Create the first API key when none exist (no authentication)
      operationId: bootstrapApiKey
      description: |
        Unauthenticated root-equivalent until a key exists. Returns 403 when `API_KEY`/`API_KEYS`
        is set or when any non-revoked key exists. See docs/API_OVERVIEW.md — Bootstrap safety.
      requestBody:
        required: false
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/CreateApiKeyRequest"
      responses:
        "201":
          description: First API key created
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ApiKeyCreatedResponse"
        "403":
          description: Bootstrap disabled (keys already exist or env bootstrap key configured)
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/StandardError"
        "503":
          description: Database not configured or unavailable
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/StandardError"

  /api-keys:
    get:
      tags: [apiKeys]
      summary: List API keys
      operationId: listApiKeys
      security:
        - bearerApiKey: []
        - headerApiKey: []
      parameters:
        - name: limit
          in: query
          schema:
            type: integer
            minimum: 1
            maximum: 100
            default: 20
        - name: cursor
          in: query
          schema:
            type: string
      responses:
        "200":
          description: Paginated API keys (no secrets)
          content:
            application/json:
