                $ref: "#/components/schemas/StandardError"
        "501":
          description: Not implemented yet
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/StandardError"

components:
  securitySchemes:
    bearerApiKey:
      type: http
      scheme: bearer
      description: "API key as Bearer token (`Authorization: Bearer <api_key>`)"
    headerApiKey:
      type: apiKey
      in: header
      name: X-API-Key
      description: "API key in `X-API-Key` header"

  schemas:
    HealthStatus:
      type: object
      required: [status]
      properties:
        status:
          type: string
          example: ok

    IdleCheckOk:
      type: object
      required: [idle]
