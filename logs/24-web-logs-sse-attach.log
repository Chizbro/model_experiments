  /workers/tasks/pull:
    post:
      tags: [workers]
      summary: Pull next task (lease reclaim, stale reclaim, assign)
      operationId: pullTask
      description: |
        Runs lease expiry (when JOB_LEASE_SECONDS > 0), reclaims jobs assigned to stale workers
        (bounded by MAX_JOB_RECLAIMS), then assigns the oldest pending job to the requesting worker.
        Returns 204 when no work. Requires a fresh heartbeat (non-stale worker).
      security:
        - bearerApiKey: []
        - headerApiKey: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/PullTaskRequest"
      responses:
        "200":
          description: Task assigned to this worker
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/PullTaskResponse"
        "204":
          description: No pending work
        "400":
          description: Invalid body
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/StandardError"
        "401":
          description: Missing or invalid API key
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/StandardError"
        "404":
          description: Worker not registered
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/StandardError"
        "409":
          description: Worker heartbeat is stale
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/StandardError"
        "503":
          description: Database not configured
          content:
