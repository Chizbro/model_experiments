  /sessions/{id}/logs/stream:
    get:
      tags: [sessions]
      summary: Stream new log lines (SSE)
      operationId: streamSessionLogs
      description: |
        Long-lived **Server-Sent Events** stream. Each message uses event name `log` and JSON
        `data` matching one [`LogEntry`](#/components/schemas/LogEntry) (same shape as
        `GET /sessions/{id}/logs`). Optional `job_id` and `level` query parameters filter the
        stream the same way as list history. Heartbeat comments keep intermediaries from timing
        out. Full event contract: `docs/SSE_EVENTS.md`.
      security:
        - bearerApiKey: []
        - headerApiKey: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: string
            format: uuid
        - name: job_id
          in: query
          schema:
            type: string
            format: uuid
        - name: level
          in: query
          schema:
            type: string
      responses:
        "200":
          description: 'Open SSE stream (Content-Type: text/event-stream)'
          content:
            text/event-stream:
              schema:
                type: string
                description: |
                  SSE frames: event "log" plus data line with JSON LogEntry; interleaved keep-alive comments.
        "400":
          description: Invalid query
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/StandardError"
        "401":
          description: Missing or invalid API key
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/StandardError"
        "404":
          description: Session not found
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/StandardError"
        "503":
          description: Database not configured
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/StandardError"

