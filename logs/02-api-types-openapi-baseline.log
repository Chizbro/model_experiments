clap = { version = "4", features = ["derive", "env"] }
reqwest = { version = "0.12", default-features = false, features = ["blocking", "json", "rustls-tls"] }

--- crates/cli/src/main.rs ---
use api_types::HealthStatusResponse;
use clap::{Parser, Subcommand};
use std::process::ExitCode;

/// Remote Harness CLI (full command surface in plan tasks 20–21).
#[derive(Parser, Debug)]
#[command(name = "remote-harness", version, about)]
struct Args {
    #[command(subcommand)]
    command: Option<Command>,

    /// Control plane base URL (overrides REMOTE_HARNESS_URL / CONTROL_PLANE_URL)
    #[arg(long, env = "CONTROL_PLANE_URL")]
    control_plane_url: Option<String>,

    /// Print shared crate version marker and exit
    #[arg(long, default_value_t = false)]
    version_marker: bool,
}

#[derive(Subcommand, Debug)]
enum Command {
    /// Call GET /health on the control plane
    Health,
}

fn main() -> ExitCode {
    let args = Args::parse();
    if args.version_marker {
        println!("api-types {}", api_types::CRATE_VERSION);
        return ExitCode::SUCCESS;
    }

    match args.command {
        Some(Command::Health) => match run_health(&resolve_base_url(&args)) {
            Ok(()) => ExitCode::SUCCESS,
            Err(e) => {
                eprintln!("{e}");
                ExitCode::FAILURE
            }
        },
        None => {
            println!(
                "remote-harness CLI stub — see docs/GETTING_STARTED.md (api-types {})",
                api_types::CRATE_VERSION
            );
            println!("Tip: cargo run -p cli -- health   # GET /health");
            println!("Tip: cargo run -p cli -- --version-marker");
            ExitCode::SUCCESS
        }
    }
}

fn resolve_base_url(args: &Args) -> String {
    args.control_plane_url
        .clone()
        .or_else(|| std::env::var("REMOTE_HARNESS_URL").ok())
        .or_else(|| std::env::var("CONTROL_PLANE_URL").ok())
        .unwrap_or_else(|| "http://127.0.0.1:3000".to_string())
}

fn run_health(base: &str) -> Result<(), String> {
    let base = base.trim_end_matches('/');
    let url = format!("{base}/health");
    let resp = reqwest::blocking::get(&url).map_err(|e| format!("request failed: {e}"))?;
    let status = resp.status();
    if !status.is_success() {
        return Err(format!(
            "HTTP {} from {} — expected 200 OK",
            status.as_u16(),
            url
        ));
    }
    let body: HealthStatusResponse = resp.json().map_err(|e| format!("invalid JSON body: {e}"))?;
    if body.status != "ok" {
        return Err(format!(
            "unexpected health payload: status={:?} (expected \"ok\")",
            body.status
        ));
    }
    println!("control plane healthy ({url})");
    Ok(())
}

