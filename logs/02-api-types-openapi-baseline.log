--- crates/server/src/main.rs ---
use api_types::{HealthStatusResponse, IdleCheckResponse};
use axum::{routing::get, Json, Router};
use std::net::SocketAddr;

#[tokio::main]
async fn main() {
    let app = Router::new()
        .route("/health", get(health))
        .route("/ready", get(ready))
        .route("/health/idle", get(health_idle))
        .route(
            "/",
            get(|| async {
                format!(
                    "remote-harness server stub (api-types {})",
                    api_types::CRATE_VERSION
                )
            }),
        );

    let port: u16 = std::env::var("PORT")
        .ok()
        .and_then(|s| s.parse().ok())
        .unwrap_or(3000);
    let addr = SocketAddr::from(([0, 0, 0, 0], port));
    let listener = tokio::net::TcpListener::bind(addr)
        .await
        .expect("bind port 3000");
    axum::serve(listener, app)
        .with_graceful_shutdown(shutdown_signal())
        .await
        .expect("server");
}

async fn health() -> Json<HealthStatusResponse> {
    Json(HealthStatusResponse::ok())
}

async fn ready() -> Json<HealthStatusResponse> {
    Json(HealthStatusResponse::ok())
}

/// Stub: always reports idle until queue wiring exists (see plan task 04).
async fn health_idle() -> Json<IdleCheckResponse> {
    Json(IdleCheckResponse {
        idle: true,
        pending_or_assigned_jobs: None,
    })
}

async fn shutdown_signal() {
    let _ = tokio::signal::ctrl_c().await;
}

