/// Apply embedded SQLx migrations from `crates/server/migrations` (idempotent).
pub async fn run_database_migrations(pool: &PgPool) -> Result<(), sqlx::migrate::MigrateError> {
    sqlx::migrate!("./migrations").run(pool).await
}

