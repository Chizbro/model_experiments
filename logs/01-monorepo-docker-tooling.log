services:
  postgres:
    image: postgres:16-alpine
    environment:
      POSTGRES_USER: remote_harness
      POSTGRES_PASSWORD: remote_harness
      POSTGRES_DB: remote_harness
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U remote_harness -d remote_harness"]
      interval: 5s
      timeout: 5s
      retries: 5
      start_period: 10s

  server:
    build:
      context: .
      dockerfile: Dockerfile
    depends_on:
      postgres:
        condition: service_healthy
    environment:
      DATABASE_URL: postgres://remote_harness:remote_harness@postgres:5432/remote_harness
      API_KEY: ${API_KEY:-dev-key-change-in-production}
    ports:
      - "3000:3000"
    restart: unless-stopped

