use clap::Parser;

/// Remote Harness CLI (full command surface in plan tasks 20–21).
#[derive(Parser, Debug)]
#[command(name = "remote-harness", version, about)]
struct Args {
    /// Print shared crate version marker and exit
    #[arg(long, default_value_t = false)]
    version_marker: bool,
}

fn main() {
    let args = Args::parse();
    if args.version_marker {
        println!("api-types {}", api_types::CRATE_VERSION);
        return;
    }
    println!(
        "remote-harness CLI stub — see docs/GETTING_STARTED.md (api-types {})",
        api_types::CRATE_VERSION
    );
    println!("Tip: cargo run -p cli -- --version-marker");
}

