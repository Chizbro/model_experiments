  worker_id: string;
  host?: string | null;
  labels: Record<string, unknown>;
  status: string;
  last_seen_at?: string | null;
  capabilities?: string[] | null;
}

export interface IdentityCredentials {
  has_git_token: boolean;
  has_agent_token: boolean;
}

