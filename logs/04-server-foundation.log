CREATE TABLE api_keys (id UUID PK, key_hash TEXT, label TEXT, created_at TIMESTAMPTZ);
CREATE TABLE identities (id TEXT PK DEFAULT 'default', agent_token, git_token, refresh_token, token_expires_at, git_provider, git_base_url, created_at, updated_at);
CREATE TABLE personas (id UUID PK, name TEXT, prompt TEXT, created_at, updated_at);
CREATE TABLE workers (id TEXT PK, host TEXT, labels JSONB, capabilities JSONB, client_version TEXT, last_seen_at, created_at);
CREATE TABLE sessions (id UUID PK, repo_url TEXT, ref TEXT, workflow TEXT, params JSONB, persona_id UUID FK, identity_id TEXT FK, status TEXT DEFAULT 'pending', retain_forever BOOLEAN, created_at, updated_at);
CREATE TABLE jobs (id UUID PK, session_id UUID FK CASCADE, worker_id TEXT FK, status TEXT DEFAULT 'pending', task_input JSONB, error_message, branch, commit_ref, mr_title, mr_description, pull_request_url, output, sentinel_reached, assistant_reply, reclaim_count INTEGER, assigned_at, created_at, updated_at);
CREATE TABLE logs (id UUID PK, session_id UUID FK CASCADE, job_id UUID FK CASCADE, worker_id TEXT, level TEXT, source TEXT, message TEXT, timestamp TIMESTAMPTZ);
Indexes: idx_logs_session_timestamp, idx_logs_job_timestamp, idx_jobs_session_id, idx_jobs_status, idx_jobs_worker_status, idx_workers_last_seen, idx_sessions_status_created
INSERT INTO identities (id) VALUES ('default');

